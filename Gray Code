class Solution {
public:
    vector<string> graycode(int n) {
        vector<string> ans;
        int len = 1 << n;

        for (int i = 0; i < len; i++) {
            int gray = i ^ (i >> 1);

            string s = "";
            for (int j = n - 1; j >= 0; j--) {
                if ((gray & (1 << j)) != 0)
                    s += '1';
                else
                    s += '0';
            }

            ans.push_back(s);
        }

        return ans;
    }
};
