class Solution {
  public:
    void segregate0and1(vector<int> &arr) {
        // code here
        int n=arr.size();
        int ind=0;
        for(int i=0;i<n;i++){
            if(arr[i]!=0){
                ind=i;
                break;
            }
        }
        
        for(int j=ind+1;j<n;j++){
            if(arr[j]==0){
                swap(arr[j],arr[ind]);
                ind++;
            }
        }
    }
};
