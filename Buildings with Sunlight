class Solution {
  public:
    int visibleBuildings(vector<int>& arr) {
        // code here
        int n=arr.size();
        int cnt=1;
        int last=arr[0];
        for(int i=1;i<n;i++){
            if(arr[i]>=last){
                cnt++;
                last=arr[i];
            }
            else{
                continue;
            }
            
        }
        
        return cnt;
    }
};
