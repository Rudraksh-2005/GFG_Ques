class Solution {
  public:
    bool isBitSet(int n) {
        // code here
          if (n == 0){
            return false;
        }
        int res = 0;
        while(n!=0){
            int rem = n % 2;
            n = n / 2;
            if (rem==0){
                return false;
            }
        }
        return true;
    }
};
