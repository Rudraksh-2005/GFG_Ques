class Solution {
  public:
    void pushZerosToEnd(vector<int>& arr) {
        // code here
        int ind=-1;
        for(int i=0;i<arr.size();i++){
            if(arr[i]==0){
                ind=i;
                break;
            }
        }
        
        if(ind==-1) return;
        
        for(int j=ind+1;j<arr.size();j++){
            if(arr[j]!=0){
                swap(arr[ind],arr[j]);
                ind++;
            }
        }
    }
};
