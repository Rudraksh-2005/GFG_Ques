class Solution {
  public:
    bool canSplit(vector<int>& arr) {
        // code here
         int n = arr.size();
         int sum=0;
         for(int i=0;i<n;i++){
             sum+=arr[i];
         }
         
         if(sum%2 !=0)return false;
         int target=sum/2;
         
         int l=0;
         while(l<n){
             sum-=arr[l];
             l++;
             if(sum==target)return true;
         }
         
         return false;
    }
  
