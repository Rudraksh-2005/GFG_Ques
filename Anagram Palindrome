class Solution {
  public:
    bool canFormPalindrome(string &s) {
        // code here
        
        int n=s.size();
        unordered_map<char,int>mpp;
        
        for(int i=0;i<n;i++){
            mpp[s[i]]++;
        }
        int odd=0;
        
        
        for(auto it:mpp){
            if(it.second%2){
                odd++;
            }
        }
        
        if(odd>1)return false;
        
        return true;
        
    }
};
