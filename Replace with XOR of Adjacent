class Solution {
  public:
    void replaceElements(vector<int>& arr) {
        // code here
        int n=arr.size();
        vector<int>ans=arr;
        
        for(int i=0;i<n;i++){
            if(i==0)arr[0]=ans[0]^ans[1];
            else if(i==n-1)arr[n-1]=ans[n-2]^ans[n-1];
            else{
                arr[i]=ans[i-1]^ans[i+1];
            }
        }
        
        
    }
};
